{
    "manifest_version": 3,
    "name": "ProdLytics — AI Productivity & Focus",
    "short_name": "ProdLytics",
    "version": "1.2.2",
    "description": "Track focus time, goals, and site habits with a dashboard and AI-style insights. Pairs with the ProdLytics web app.",
    "minimum_chrome_version": "120",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting",
        "notifications",
        "idle",
        "alarms",
        "webNavigation"
    ],
    "host_permissions": [
        "https://prodlytics.vercel.app/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "externally_connectable": {
        "matches": [
            "https://prodlytics.vercel.app/*"
        ]
    }
}