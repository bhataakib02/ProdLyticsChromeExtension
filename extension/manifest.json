{
    "manifest_version": 3,
    "name": "AI Productivity Platform",
    "version": "1.0.6",
    "description": "SaaS-level productivity tracker with AI insights.",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting",
        "notifications",
        "idle",
        "alarms",
        "identity",
        "webNavigation"
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "externally_connectable": {
        "matches": [
            "http://localhost:3000/*",
            "http://127.0.0.1:3000/*"
        ]
    }
}