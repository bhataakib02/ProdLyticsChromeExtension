# Copy to .env.local for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables.

# MongoDB (required for API routes)
# MONGO_URI=mongodb+srv://...

# One-time admin user creation (same DB as the app — use this if Atlas shows no admin@gmail.com)
# 1) Set a long random string here, restart `npm run dev`
# 2) POST http://localhost:3000/api/auth/setup-admin with header x-setup-secret: <same value>
#    Body: {"email":"admin@gmail.com","password":"admin123","name":"Admin"}
# ADMIN_SETUP_SECRET=change-me-to-a-long-random-string

# Public dashboard URL (used in privacy policy links; defaults to prodlytics.vercel.app in code if unset)
# NEXT_PUBLIC_SITE_URL=https://prodlytics.vercel.app

# Shown on /privacy-policy (overrides built-in default if set)
# NEXT_PUBLIC_SUPPORT_EMAIL=aakibbhat01@gmail.com

# Optional: e.g. "United States (Vercel) / EU (MongoDB Atlas — Frankfurt)"
# NEXT_PUBLIC_DATA_REGION=

# NextAuth (required for Google OAuth + credentials sessions)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=replace-with-long-random-string

# Google OAuth (for NextAuth Google provider)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: set to "true" to open AI Coach + week-compare API without Pro (local QA only; never in production).
# NEXT_PUBLIC_AI_COACH_PREMIUM_BYPASS=
# AI_COACH_PREMIUM_BYPASS=

# Stripe billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
# NEXT_PUBLIC_APP_URL=http://localhost:3000
